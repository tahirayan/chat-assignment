# ─────────────────────────────────────────────────────────────────────────────
# Chat — environment example
# Copy to .env at the relevant app root, then fill in real values.
# .env is gitignored; .env.example is the source of truth for shape.
# ─────────────────────────────────────────────────────────────────────────────

# ── apps/api (runtime) ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Dev: relative file. Prod (Railway): file:/data/chat.db (volume mount).
DATABASE_URL=file:./chat.db

# Min 32 chars. Generate locally with `openssl rand -base64 48` or similar.
JWT_SECRET=change-me-min-32-chars-of-random-bytes-here

# Comma-separated for dev; exact Netlify domain in prod (no trailing slash).
CORS_ORIGIN=http://localhost:4200

# Stripe — get from https://dashboard.stripe.com (test mode)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Web Push (Phase 20) — generate once with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is also exposed to the web (VITE_VAPID_PUBLIC_KEY below).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Must be mailto: URI or https URL — Push services may contact the
# operator (you) about abuse via this identifier.
VAPID_SUBJECT=mailto:you@example.com

# ── apps/web (build-time; VITE_ prefix required) ─────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Same value as VAPID_PUBLIC_KEY above (browser needs it to build the subscription).
VITE_VAPID_PUBLIC_KEY=
